
void drawGrid() {
  for (int i = 0; i<20; i++) {
    for (int j = 0; j<10; j++) {
      if (grid[i][j] == -1) {
        fill(220, 90, 60);
      }
      if (grid[i][j] == 0) {
        fill(255);
      }
      if (grid[i][j] >= 1) {
        fill(70, 200, 105);
      }
      square(175+35*j, 70+35*i, 35);
    }
  }
}
