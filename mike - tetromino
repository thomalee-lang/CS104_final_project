class Tetromino{
  int[][] piece;
  int x, y;
  int size = 35;

  Tetromino(int[][] piece, int y){
    this.piece = piece;
    this.y = y;
  }

void move(){
    y += size;
  }

void rotation(){
  int rows = piece.length;
  int cols = piece[0].length;
  int[][] rotated = new int[cols][rows];
  for(int r = 0; r < rows; r++){
      for(int c = 0; c < cols; c++){
        rotated[c][rows - 1 - r] = piece[r][c];
      }
    }
    piece = rotated;
  }
}
