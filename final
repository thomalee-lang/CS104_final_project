//global variables
Grid grid;
Block b1;
Tetromino t;
int screen;
//represents the block moving down every # of currentSpeed frames
//higher currentSpeed is  lower speed
int currentSpeed;
int totalPoints;
int linesGone;
int introOpacity;


//initialize global variables and initial blocks
void setup() {
  size(720, 720);
  strokeWeight(2);
  grid = new Grid();
  b1 = new Block(int(random(7)), 3, 0);
  t = new Tetromino(b1.shapes[b1.shape], b1.xIndex, b1.yIndex);
  screen = 0;
  currentSpeed = 50;
  introOpacity = 0;
}

//displays each screen and then the game
void draw() {
  if (screen == 0) {
    playTeamAnimation();
  } else if(screen == 1){
    showStartScreen();
  } 
  else if(screen == 2){
    showObjectiveScreen();
  } 
  else if(screen == 3){
    background(0);
    grid.display();
    b1.render();
    b1.update(t);
    println(currentSpeed);
    
    //displays total points
    textAlign(LEFT);
    fill(255);
    textSize(24);
    text("SCORE", 50, 100);
    textSize(40);
    text(totalPoints, 50, 140);
    
    //displays level and speed
    textSize(20);
    fill(180);
    text("LINES: " + linesGone, 50, 200);
    text("SPEED: " + (55 - currentSpeed)/5, 50, 230); 
  }
}
 
//user input
void keyPressed() {
  if(screen == 1 && key == 's'){
    screen = 2;
  }
  else if (screen == 2 && key == 's') {
    screen = 3;
    rectMode(CORNER);
  }
  if (screen==3) {
    if (keyCode==UP) {
      t.rotation();
    }
    if (keyCode==DOWN) {
      t.speed=5;
    }
    if (keyCode==LEFT) {
      t.moveLeft();
    }
    if (keyCode==RIGHT) {
      t.moveRight();
    }
    if(key == ' '){
      t.hardDrop();
    }
  }
}

//used to set speed back to current speed after hard/soft drop
void keyReleased() {
  if (screen==3) {
    if (keyCode == DOWN || key == ' ') {
      t.speed=currentSpeed;
    }
  }
}

//intro team animation
void playTeamAnimation(){
  background(0);
  noStroke();
  
  fill(30, 230, 220, introOpacity);
  rect(width/2 - 150, height/2 - 80, 40, 120);
  fill(140, 25, 180, introOpacity);
  ellipse(width/2, height/2 - 20, 100, 100);
  fill(245, 230, 65, introOpacity);
  rect(width/2 + 110, height/2 - 80, 40, 120);
  
  textAlign(CENTER);
  fill(255, introOpacity);
  textSize(60);
  text("MALfunction", width/2, height/2 + 100);
  
  introOpacity += 2;
  //once done loading, goes to game screen
  if (introOpacity > 350) {
    screen = 1;
  }
}

